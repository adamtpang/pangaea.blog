---
interface Props {
  id: string;
  title?: string;
  start?: number;
}

const { id, title = 'YouTube video', start } = Astro.props;
const src = start
  ? `https://www.youtube-nocookie.com/embed/${id}?start=${start}`
  : `https://www.youtube-nocookie.com/embed/${id}`;
---

<div class="embed embed-yt">
  <iframe
    src={src}
    title={title}
    loading="lazy"
    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
    allowfullscreen
  ></iframe>
</div>
