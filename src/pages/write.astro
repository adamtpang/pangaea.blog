---
import Base from '../layouts/Base.astro';
export const prerender = false;
---

<Base title="Write · Pangaea" description="Backstage editor for Pangaea posts.">
  <div class="write-shell">
    <h1>
      <span>Write</span>
      <span class="backstage">Backstage</span>
    </h1>

    <p class="meta">
      Fill four fields. Click build. Edit if you want. Publish.
    </p>

    <form class="write-form" id="post-form">
      <div>
        <label for="title">Title</label>
        <input
          type="text"
          id="title"
          name="title"
          placeholder="e.g. Why a thousand"
          required
        />
      </div>

      <div>
        <label for="cover">Cover image URL (optional)</label>
        <input
          type="url"
          id="cover"
          name="cover"
          placeholder="https://... (paste any image URL)"
        />
      </div>

      <div>
        <label for="outline">Outline (one line per beat)</label>
        <textarea
          id="outline"
          name="outline"
          rows="6"
          placeholder={'The hook. One sentence.\nThe thing. Why it matters.\nThe turn. A specific example or quote.\nThe close.'}
          required></textarea>
      </div>

      <div class="write-row">
        <div>
          <label for="goal">Word goal</label>
          <input type="number" id="goal" name="goal" value="300" min="50" max="2000" step="50" />
        </div>
        <div>
          <label for="slug">Slug</label>
          <input type="text" id="slug" name="slug" required />
        </div>
      </div>

      <div class="write-actions">
        <button type="button" class="btn ghost" id="build-btn">Build draft &darr;</button>
        <span class="write-status" id="build-status"></span>
      </div>
    </form>

    <hr id="divider" style="display:none;" />

    <form class="write-form" id="publish-form" style="display:none;">
      <div>
        <label for="body">Body (MDX) <span id="word-count" class="word-count"></span></label>
        <textarea id="body" name="body" class="body" spellcheck="true" required></textarea>
      </div>
      <div class="write-actions">
        <button type="submit" class="btn" id="publish-btn">Publish &rarr; Vercel rebuilds</button>
        <button type="button" class="btn ghost" id="reset-btn">Discard &amp; start over</button>
        <span class="write-status" id="publish-status"></span>
      </div>
      <div class="write-help">
        <strong>Embeds you can drop in the body:</strong><br />
        <code>&lt;Quote attribution="Author"&gt;Pull quote.&lt;/Quote&gt;</code><br />
        <code>&lt;YouTube id="dQw4w9WgXcQ" /&gt;</code><br />
        <code>&lt;Spotify uri="track/0NeJjNlprGfZpeX2LQuN6c" /&gt;</code><br />
        <code>&lt;SoundCloud url="https://soundcloud.com/..." /&gt;</code><br />
        <code>&lt;Figure src="/images/foo.jpg" alt="..." caption="..." /&gt;</code><br />
        <br />
        Posts publish with <code>draft: false</code> and go live in ~30s. Edit the file in
        the repo later to flip <code>draft: true</code> if you want to pull it. Add
        <code>number: N</code> for an issue badge.
      </div>
    </form>
  </div>
</Base>

<script>
  const $ = <T extends Element = HTMLElement>(id: string) => document.getElementById(id) as T;
  const titleInput = $<HTMLInputElement>('title');
  const coverInput = $<HTMLInputElement>('cover');
  const outlineInput = $<HTMLTextAreaElement>('outline');
  const goalInput = $<HTMLInputElement>('goal');
  const slugInput = $<HTMLInputElement>('slug');
  const buildBtn = $<HTMLButtonElement>('build-btn');
  const buildStatus = $('build-status');
  const publishForm = $<HTMLFormElement>('publish-form');
  const publishBtn = $<HTMLButtonElement>('publish-btn');
  const publishStatus = $('publish-status');
  const bodyInput = $<HTMLTextAreaElement>('body');
  const wordCount = $('word-count');
  const resetBtn = $<HTMLButtonElement>('reset-btn');
  const divider = $('divider');

  const setStatus = (el: HTMLElement, msg: string, kind: 'ok' | 'error' | '' = '') => {
    el.textContent = msg;
    el.className = `write-status${kind ? ' ' + kind : ''}`;
  };

  const slugify = (s: string) =>
    s
      .toLowerCase()
      .normalize('NFKD')
      .replace(/[̀-ͯ]/g, '')
      .replace(/[‘’']/g, '')
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-+|-+$/g, '')
      .slice(0, 80);

  const todayIso = () => {
    const d = new Date();
    const m = String(d.getMonth() + 1).padStart(2, '0');
    const day = String(d.getDate()).padStart(2, '0');
    return `${d.getFullYear()}-${m}-${day}`;
  };

  // Slug auto-tracks title until the user edits it manually.
  let slugTouched = false;
  slugInput?.addEventListener('input', () => {
    slugTouched = true;
  });
  titleInput?.addEventListener('input', () => {
    if (!slugTouched) slugInput.value = slugify(titleInput.value);
  });

  const updateWords = () => {
    if (!wordCount || !bodyInput) return;
    const n = bodyInput.value.trim().split(/\s+/).filter(Boolean).length;
    const goal = parseInt(goalInput.value, 10) || 0;
    wordCount.textContent = goal ? `${n} / ${goal} words` : `${n} words`;
  };
  bodyInput?.addEventListener('input', updateWords);

  function buildMdx() {
    const title = titleInput.value.trim();
    const cover = coverInput.value.trim();
    const outlineLines = outlineInput.value
      .split('\n')
      .map((l) => l.trim())
      .filter(Boolean);
    const date = todayIso();

    const fmLines = [
      '---',
      `title: ${JSON.stringify(title)}`,
      `date: ${date}`,
    ];
    if (cover) fmLines.push(`cover: ${JSON.stringify(cover)}`);
    fmLines.push('draft: false', '---', '');

    const importLine =
      `import { Quote, YouTube, Spotify, SoundCloud, Figure } from '../../components/embeds';\n`;

    const coverBlock = cover
      ? `<Figure src="${cover}" alt="${title}" />\n\n`
      : '';

    const body = outlineLines.length
      ? outlineLines
          .map((line) => `${line}\n\n[expand: write ~${Math.round((parseInt(goalInput.value, 10) || 300) / Math.max(outlineLines.length, 1))} words here]`)
          .join('\n\n')
      : '[your post here]';

    return `${fmLines.join('\n')}${importLine}\n${coverBlock}${body}\n`;
  }

  buildBtn?.addEventListener('click', () => {
    const title = titleInput.value.trim();
    const outline = outlineInput.value.trim();
    if (!title || !outline) {
      setStatus(buildStatus, 'Title and outline required.', 'error');
      return;
    }
    if (!slugInput.value) slugInput.value = slugify(title);
    bodyInput.value = buildMdx();
    divider.style.display = 'block';
    publishForm.style.display = 'grid';
    updateWords();
    setStatus(buildStatus, 'Draft built. Edit + publish below.', 'ok');
    bodyInput.focus();
    bodyInput.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });

  publishForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    publishBtn.disabled = true;
    setStatus(publishStatus, 'Publishing…');

    try {
      const res = await fetch('/api/write/publish', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({
          title: titleInput.value,
          slug: slugInput.value,
          body: bodyInput.value,
        }),
      });
      if (!res.ok) {
        const { error } = await res.json().catch(() => ({ error: res.statusText }));
        throw new Error(error || 'Publish failed');
      }
      const { url, path } = await res.json();
      setStatus(publishStatus, '', 'ok');
      publishStatus.innerHTML =
        `<span class="ok">Committed <code>${path}</code>. Vercel is rebuilding... </span>` +
        `<a href="${url}" target="_blank" rel="noopener">${url}</a>`;
    } catch (err: any) {
      setStatus(publishStatus, err.message, 'error');
    } finally {
      publishBtn.disabled = false;
    }
  });

  resetBtn?.addEventListener('click', () => {
    if (!confirm('Discard this draft and start over?')) return;
    bodyInput.value = '';
    publishForm.style.display = 'none';
    divider.style.display = 'none';
    setStatus(publishStatus, '');
    setStatus(buildStatus, '');
    titleInput.focus();
  });
</script>
