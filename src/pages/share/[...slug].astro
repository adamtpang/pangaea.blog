---
import { getCollection, type CollectionEntry } from 'astro:content';

export const prerender = true;

export async function getStaticPaths() {
  const epoch = new Date('1971-01-01').valueOf();
  const posts = await getCollection(
    'posts',
    ({ data }) => !data.draft && data.date.valueOf() >= epoch
  );
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { Content } = await post.render();
const { data } = post;
const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=1080" />
    <title>{data.title} · share</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      :root {
        --bg: #f6f3ee;
        --ink: #1a1a1a;
        --muted: #6b6258;
        --rule: #d8d2c7;
        --accent: #8a3b1f;
        --accent-soft: #b8896c;
        --serif: 'Iowan Old Style', 'Charter', 'Georgia', 'Cambria', serif;
        --sans: 'IBM Plex Sans', 'Helvetica Neue', system-ui, sans-serif;
        --mono: 'IBM Plex Mono', 'Menlo', 'Consolas', monospace;
      }
      * {
        box-sizing: border-box;
      }
      html,
      body {
        margin: 0;
        padding: 0;
        background: #2b2722;
        font-family: var(--serif);
      }
      .share-page {
        width: 1080px;
        margin: 40px auto;
        background: var(--bg);
        color: var(--ink);
        padding: 80px 90px;
        font-size: 28px;
        line-height: 1.55;
        box-shadow: 0 30px 90px rgba(0, 0, 0, 0.4);
        position: relative;
        overflow: hidden;
      }
      .share-page::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 8px;
        background: var(--accent);
      }
      .masthead {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        font-family: var(--sans);
        font-size: 20px;
        color: var(--muted);
        letter-spacing: 0.04em;
        margin-bottom: 60px;
        padding-bottom: 20px;
        border-bottom: 1px solid var(--rule);
      }
      .masthead .brand {
        font-family: var(--serif);
        font-size: 28px;
        font-weight: 600;
        color: var(--ink);
        letter-spacing: 0.01em;
      }
      .masthead .brand .dot {
        color: var(--accent);
      }
      .masthead .num {
        font-family: var(--mono);
        color: var(--accent);
        font-size: 18px;
      }
      h1 {
        font-family: var(--serif);
        font-size: 76px;
        line-height: 1.05;
        font-weight: 600;
        letter-spacing: -0.015em;
        margin: 0 0 32px;
      }
      .blurb {
        font-style: italic;
        color: var(--muted);
        font-size: 32px;
        line-height: 1.4;
        margin-bottom: 56px;
        border-left: 4px solid var(--accent-soft);
        padding-left: 24px;
      }
      .prose {
        font-size: 28px;
        line-height: 1.55;
      }
      .prose p {
        margin: 0 0 1.1em;
      }
      .prose p:first-child {
        margin-top: 0;
      }
      .prose a {
        color: var(--accent);
        text-decoration: underline;
        text-underline-offset: 4px;
      }
      .prose strong {
        color: var(--ink);
        font-weight: 700;
      }
      .prose em {
        font-style: italic;
      }
      .prose blockquote {
        border-left: 4px solid var(--accent-soft);
        padding-left: 24px;
        margin: 32px 0;
        font-style: italic;
        color: var(--muted);
      }
      .prose .pullquote {
        font-size: 36px;
        line-height: 1.35;
        font-style: italic;
        border-left: 5px solid var(--accent);
        padding: 12px 0 12px 32px;
        margin: 56px 0;
      }
      .prose .pullquote .attribution {
        display: block;
        font-style: normal;
        font-family: var(--sans);
        font-size: 22px;
        color: var(--muted);
        margin-top: 16px;
      }
      .prose .pullquote .attribution::before {
        content: '/ ';
        color: var(--accent-soft);
      }
      .prose .embed {
        margin: 48px 0;
      }
      .prose .embed iframe {
        width: 100%;
        border: 0;
      }
      .prose .embed-yt {
        aspect-ratio: 16 / 9;
      }
      .prose .embed-yt iframe {
        height: 100%;
      }
      .prose .embed-spotify iframe {
        height: 152px;
        border-radius: 12px;
      }
      .prose .embed-soundcloud iframe {
        height: 166px;
      }
      .prose .embed-figure {
        margin: 48px 0;
      }
      .prose .embed-figure img {
        max-width: 100%;
        height: auto;
        display: block;
        margin: 0 auto;
        border-radius: 4px;
      }
      .prose .embed-figure figcaption {
        font-family: var(--sans);
        font-size: 22px;
        color: var(--muted);
        text-align: center;
        margin-top: 16px;
      }
      .colophon {
        margin-top: 80px;
        padding-top: 32px;
        border-top: 1px solid var(--rule);
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        font-family: var(--sans);
        font-size: 20px;
        color: var(--muted);
      }
      .colophon .url {
        font-family: var(--mono);
        color: var(--accent);
        letter-spacing: 0.02em;
      }
      .help {
        max-width: 1080px;
        margin: 0 auto 40px;
        padding: 16px 20px;
        font-family: var(--sans);
        font-size: 14px;
        color: #c9c2b6;
        text-align: center;
      }
      .help a {
        color: #fff;
      }
      @media print {
        .help {
          display: none;
        }
        body {
          background: #fff;
        }
        .share-page {
          margin: 0;
          box-shadow: none;
        }
      }
    </style>
  </head>
  <body>
    <p class="help">
      Screenshot this view (Cmd+Shift+4 on Mac · Win+Shift+S on Windows) and post to X / IG. The
      framed area is exactly 1080px wide. <a href={`/posts/${post.slug}/`}>back to the post</a>
    </p>

    <article class="share-page">
      <header class="masthead">
        <span class="brand">Pangaea<span class="dot">.</span></span>
        <span>
          {data.number !== undefined && (
            <span class="num">№ {String(data.number).padStart(3, '0')} &middot;&nbsp;</span>
          )}
          {fmt(data.date)}
        </span>
      </header>

      <h1>{data.title}</h1>

      {data.blurb && <p class="blurb">{data.blurb}</p>}

      <div class="prose">
        <Content />
      </div>

      <footer class="colophon">
        <span>by Adam Pang</span>
        <span class="url">pangaea.blog/posts/{post.slug}</span>
      </footer>
    </article>
  </body>
</html>
