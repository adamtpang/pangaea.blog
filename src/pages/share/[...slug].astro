---
import { getCollection, type CollectionEntry } from 'astro:content';

export const prerender = true;

export async function getStaticPaths() {
  const epoch = new Date('1971-01-01').valueOf();
  const posts = await getCollection(
    'posts',
    ({ data }) => !data.draft && data.date.valueOf() >= epoch
  );
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { Content } = await post.render();
const { data } = post;
const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=1080" />
    <title>{data.title} · share</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      /* /share v2 — fixed-proportion screenshot essay for X / IG / threads.
         Frame is 1080 × 2160 (canonical 1:2). Take a browser screenshot of the
         framed area and post. */
      :root {
        --bg: #f3f7f6;
        --surface: #ffffff;
        --ink: #14201f;
        --muted: #4d635f;
        --rule: #cad9d3;
        --accent: #176079;       /* ocean */
        --accent-soft: #6a9bad;
        --land: #2f6b4f;         /* the supercontinent: identity */
        --serif: 'Iowan Old Style', 'Charter', 'Georgia', 'Cambria', serif;
        --sans: 'IBM Plex Sans', 'Helvetica Neue', system-ui, sans-serif;
        --mono: 'IBM Plex Mono', 'Menlo', 'Consolas', monospace;
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; font-family: var(--serif); }
      body {
        background: #0e1c20; /* deep space around the framed essay */
        min-height: 100vh;
      }
      .help {
        max-width: 1080px;
        margin: 24px auto 16px;
        padding: 0 20px;
        font-family: var(--sans);
        font-size: 13px;
        color: #93aaa4;
        text-align: center;
        line-height: 1.5;
      }
      .help a { color: #ffffff; }
      .help code {
        background: rgba(255,255,255,0.08);
        padding: 1px 6px;
        border-radius: 2px;
        font-family: var(--mono);
      }

      /* The frame. 1080 × 2160 fixed. Content longer than the frame extends
         below it (still inside the off-white card) so nothing gets clipped;
         take a 1080×2160 screenshot of the top portion for square-ish
         platforms, or a long screenshot for full-essay sharing. */
      .share-frame {
        width: 1080px;
        min-height: 2160px;
        margin: 0 auto 40px;
        background: var(--bg);
        color: var(--ink);
        padding: 100px 110px 90px;
        position: relative;
        overflow: hidden;
        box-shadow: 0 40px 100px rgba(0, 0, 0, 0.55);
        font-size: 30px;
        line-height: 1.55;
      }
      /* The supercontinent stripe at top. */
      .share-frame::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 10px;
        background: var(--land);
      }

      /* Masthead */
      .masthead {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 1rem;
        font-family: var(--sans);
        font-size: 20px;
        color: var(--muted);
        letter-spacing: 0.04em;
        padding-bottom: 24px;
        border-bottom: 1px solid var(--rule);
        margin-bottom: 64px;
      }
      .masthead .brand {
        font-family: var(--serif);
        font-size: 30px;
        font-weight: 600;
        color: var(--ink);
        letter-spacing: 0.01em;
      }
      .masthead .brand .dot { color: var(--land); }
      .masthead .num {
        font-family: var(--mono);
        color: var(--land);
        font-size: 18px;
        margin-right: 8px;
      }

      /* The headline. Big serif, tight. */
      h1.headline {
        font-family: var(--serif);
        font-size: 86px;
        line-height: 1.04;
        font-weight: 600;
        letter-spacing: -0.015em;
        margin: 0 0 36px;
        color: var(--ink);
      }

      /* The italic blurb with ocean accent bar. */
      .blurb {
        font-style: italic;
        color: var(--muted);
        font-size: 34px;
        line-height: 1.4;
        margin: 0 0 64px;
        border-left: 5px solid var(--accent);
        padding: 4px 0 4px 26px;
      }

      /* Body prose. */
      .prose { font-size: 30px; line-height: 1.55; }
      .prose p { margin: 0 0 1.1em; }
      .prose p:first-child { margin-top: 0; }
      .prose a {
        color: var(--accent);
        text-decoration: underline;
        text-underline-offset: 4px;
      }
      .prose strong { color: var(--ink); font-weight: 700; }
      .prose em { font-style: italic; }

      .prose blockquote {
        border-left: 5px solid var(--accent-soft);
        padding-left: 26px;
        margin: 36px 0;
        font-style: italic;
        color: var(--muted);
      }
      .prose .pullquote {
        font-size: 40px;
        line-height: 1.3;
        font-style: italic;
        border-left: 6px solid var(--accent);
        padding: 16px 0 16px 36px;
        margin: 64px 0;
      }
      .prose .pullquote .attribution {
        display: block;
        font-style: normal;
        font-family: var(--sans);
        font-size: 22px;
        color: var(--muted);
        margin-top: 18px;
      }
      .prose .pullquote .attribution::before {
        content: '/ ';
        color: var(--accent-soft);
      }

      /* Embeds */
      .prose .embed { margin: 56px 0; }
      .prose .embed iframe { width: 100%; border: 0; }
      .prose .embed-yt { aspect-ratio: 16 / 9; }
      .prose .embed-yt iframe { height: 100%; }
      .prose .embed-spotify iframe { height: 152px; border-radius: 12px; }
      .prose .embed-soundcloud iframe { height: 166px; }
      .prose .embed-figure { margin: 56px 0; }
      .prose .embed-figure img {
        max-width: 100%;
        height: auto;
        display: block;
        margin: 0 auto;
        border-radius: 2px;
      }
      .prose .embed-figure figcaption {
        font-family: var(--sans);
        font-size: 22px;
        color: var(--muted);
        text-align: center;
        margin-top: 18px;
      }

      /* Optional 3-column key-takeaway grid (Codia-template style).
         Author opt-in via `bullets:` array in post frontmatter. */
      .takeaways {
        margin: 80px 0 32px;
        padding: 36px 36px 24px;
        border: 1px solid var(--rule);
        background: var(--surface);
      }
      .takeaways-label {
        font-family: var(--sans);
        font-size: 14px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--land);
        margin: 0 0 24px;
      }
      .takeaways-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px 32px;
      }
      .takeaways-grid li {
        list-style: none;
        font-size: 22px;
        line-height: 1.4;
        color: var(--ink);
        padding-top: 14px;
        border-top: 1px solid var(--rule);
      }

      /* Colophon */
      .colophon {
        margin-top: 96px;
        padding-top: 36px;
        border-top: 1px solid var(--rule);
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        font-family: var(--sans);
        font-size: 22px;
        color: var(--muted);
      }
      .colophon .by { letter-spacing: 0.04em; }
      .colophon .url {
        font-family: var(--mono);
        color: var(--land);
        letter-spacing: 0.02em;
      }

      /* Frame guide overlay so you know where the 1080×2160 cut is.
         Activate with ?guide=1 in the URL. Toggled by data attribute. */
      [data-guide='1'] .share-frame::after {
        content: 'Screenshot cut · 1080 × 2160';
        position: absolute;
        top: 2160px;
        left: 0;
        right: 0;
        height: 0;
        border-top: 2px dashed var(--accent);
        font-family: var(--mono);
        font-size: 16px;
        color: var(--accent);
        padding-top: 6px;
        text-align: center;
      }

      @media print {
        .help { display: none; }
        body { background: #ffffff; }
        .share-frame { margin: 0; box-shadow: none; }
      }
    </style>
  </head>
  <body>
    <p class="help">
      Screenshot the framed essay (Cmd+Shift+4 on Mac · Win+Shift+S on Windows) and post to X / IG.
      The frame is <code>1080 × 2160</code> — append <code>?guide=1</code> to the URL to see the cut.
      <a href={`/posts/${post.slug}/`}>back to the post</a>
    </p>

    <article class="share-frame">
      <header class="masthead">
        <span class="brand">Pangaea<span class="dot">.</span></span>
        <span>
          {data.number !== undefined && (
            <span class="num">№ {String(data.number).padStart(3, '0')}</span>
          )}
          {fmt(data.date)}
        </span>
      </header>

      <h1 class="headline">{data.title}</h1>

      {data.blurb && <p class="blurb">{data.blurb}</p>}

      <div class="prose">
        <Content />
      </div>

      {data.bullets && data.bullets.length > 0 && (
        <section class="takeaways">
          <p class="takeaways-label">Takeaways</p>
          <ul class="takeaways-grid">
            {data.bullets.map((b) => <li>{b}</li>)}
          </ul>
        </section>
      )}

      <footer class="colophon">
        <span class="by">by Adam Pang</span>
        <span class="url">pangaea.blog/posts/{post.slug}</span>
      </footer>
    </article>

    <script is:inline>
      // Toggle the 1080×2160 cut guide via ?guide=1
      const params = new URLSearchParams(location.search);
      if (params.get('guide') === '1') {
        document.documentElement.dataset.guide = '1';
      }
    </script>
  </body>
</html>
