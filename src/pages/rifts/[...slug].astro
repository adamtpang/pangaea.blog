---
import Base from '../../layouts/Base.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const rifts = await getCollection('rifts', ({ data }) => !data.draft);
  return rifts.map((rift) => ({
    params: { slug: rift.slug },
    props: { rift },
  }));
}

interface Props {
  rift: CollectionEntry<'rifts'>;
}

const { rift } = Astro.props;
const { Content } = await rift.render();
const { data } = rift;

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base title={`${data.title} — Pangaea`} description={data.blurb}>
  <article class="rift">
    <header>
      <h1>{data.title}</h1>
      <p class="rift-meta">
        <span class="num">№ {String(data.number).padStart(3, '0')}</span>
        {fmt(data.date)}
      </p>
    </header>

    {data.blurb && <p class="prose"><em>{data.blurb}</em></p>}

    <div class="prose">
      <Content />
    </div>

    <section class="curation">
      <div class="label">App</div>
      <div class="pick">
        <a href={data.app.url}>{data.app.name}</a>
      </div>
      <p class="note">{data.app.note}</p>
    </section>

    <section class="curation">
      <div class="label">Essay</div>
      <div class="pick">
        <a href={data.essay.url}>{data.essay.title}</a>
      </div>
      <div class="by">by {data.essay.author}</div>
      <p class="note">{data.essay.note}</p>
    </section>

    <section class="curation">
      <div class="label">Song</div>
      <div class="pick">
        <a href={data.song.url}>{data.song.title}</a>
      </div>
      <div class="by">{data.song.artist}</div>
      <p class="note">{data.song.note}</p>
    </section>

    {
      data.extra && (
        <section class="curation">
          <div class="label">{data.extra.kind}</div>
          {data.extra.url && (
            <div class="pick">
              <a href={data.extra.url}>{data.extra.caption ?? data.extra.url}</a>
            </div>
          )}
          {!data.extra.url && data.extra.caption && <p class="note">{data.extra.caption}</p>}
        </section>
      )
    }

    <hr />
    <p class="meta">
      <a href="/rifts/">&larr; All rifts</a> &nbsp; · &nbsp;
      <a href="https://adamtpang.substack.com">Get rifts in your inbox</a>
    </p>
  </article>
</Base>
