---
import Base from '../../layouts/Base.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const essays = await getCollection('essays', ({ data }) => !data.draft);
  return essays.map((essay) => ({
    params: { slug: essay.slug },
    props: { essay },
  }));
}

interface Props {
  essay: CollectionEntry<'essays'>;
}

const { essay } = Astro.props;
const { Content } = await essay.render();
const { data } = essay;

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base title={`${data.title} — Pangaea`} description={data.blurb}>
  <article>
    <h1>{data.title}</h1>
    <p class="meta">{fmt(data.date)}</p>
    {data.blurb && <p><em>{data.blurb}</em></p>}
    <div class="prose">
      <Content />
    </div>
    <hr />
    <p class="meta"><a href="/essays/">&larr; All essays</a></p>
  </article>
</Base>
