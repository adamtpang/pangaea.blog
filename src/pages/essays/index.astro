---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const essays = (await getCollection('essays', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base title="Essays — Pangaea">
  <h1>Essays</h1>
  <p class="meta">Longer pieces. Less frequent than rifts, more considered.</p>

  {essays.length === 0 && <p class="meta">Nothing here yet.</p>}

  <ul class="rift-list">
    {
      essays.map((e) => (
        <li>
          <span class="num">·</span>
          <span>
            <a href={`/essays/${e.slug}/`}>{e.data.title}</a>
            {e.data.blurb && <span class="blurb">{e.data.blurb}</span>}
            <span class="date">{fmt(e.data.date)}</span>
          </span>
        </li>
      ))
    }
  </ul>
</Base>
