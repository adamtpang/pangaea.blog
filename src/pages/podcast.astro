---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const episodes = (await getCollection('episodes', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const thumb = (id: string) =>
  `https://i.ytimg.com/vi/${id}/hqdefault.jpg`;
---

<Base
  title="Listen · Pangaea"
  description="The spoken side of Pangaea. Long-form conversations, on YouTube."
>
  <h1>Listen</h1>

  {episodes.length === 0 && (
    <>
      <p class="meta">The spoken side of Pangaea. Coming soon.</p>
      <p>
        Conversations on memetics, relationships, and the shape of attention. Each episode
        ships as a YouTube embed with show notes. If you want a ping when the first one drops,
        say so via <a href="https://adampang.com/hi">adampang.com/hi</a>.
      </p>
    </>
  )}

  {episodes.length > 0 && (
    <>
      <p class="meta">{episodes.length} episode{episodes.length === 1 ? '' : 's'}.</p>
      <ul class="media-grid">
        {episodes.map((ep) => (
          <li>
            <a href={`/podcast/${ep.slug}/`} class="media-card">
              {ep.data.youtube && (
                <div class="media-thumb">
                  <img src={thumb(ep.data.youtube)} alt={ep.data.title} loading="lazy" />
                </div>
              )}
              <div class="media-body">
                {ep.data.episode !== undefined && (
                  <span class="media-num">Ep. {ep.data.episode}</span>
                )}
                <h2 class="media-title">{ep.data.title}</h2>
                {ep.data.blurb && <p class="media-blurb">{ep.data.blurb}</p>}
                <span class="media-date">
                  {fmt(ep.data.date)}
                  {ep.data.guest && <span> · with {ep.data.guest}</span>}
                </span>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </>
  )}
</Base>
