---
import Base from '../../layouts/Base.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { Content } = await post.render();
const { data } = post;

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base title={`${data.title} — Pangaea`} description={data.blurb}>
  <article class="post">
    <header>
      <h1>{data.title}</h1>
      <p class="post-meta">{fmt(data.date)}</p>
    </header>

    {data.blurb && <p class="prose blurb-line"><em>{data.blurb}</em></p>}

    <div class="prose">
      <Content />
    </div>

    <hr />
    <p class="meta">
      <a href="/posts/">&larr; All posts</a> &nbsp; · &nbsp;
      <a href="https://adampang.com/hi">Tell me what you think</a>
    </p>
  </article>
</Base>
