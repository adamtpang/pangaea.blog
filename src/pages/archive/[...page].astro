---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import type { GetStaticPaths, Page } from 'astro';

// The Lindy-style archive: one dense chronological wall of everything shipped.
// Paginated so it stays fast at 1,000 essays. Published only, never drafts.
export const getStaticPaths = (async ({ paginate }) => {
  const epoch = new Date('1971-01-01').valueOf();
  const posts = (await getCollection('posts', ({ data }) => !data.draft && data.date.valueOf() >= epoch))
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return paginate(posts, { pageSize: 50 });
}) satisfies GetStaticPaths;

const { page } = Astro.props as { page: Page<any> };

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<Base title="Archive · Pangaea" description="Everything shipped, newest first.">
  <h1>Archive</h1>
  <p class="hero">
    Everything shipped, newest first. The work is the point; the volume is the
    method. <a href="/work/">See the whole field</a>.
  </p>

  <p class="meta arch-count">
    {page.total} published · page {page.currentPage} of {page.lastPage}
  </p>

  <ol class="arch">
    {page.data.map((p: any) => (
      <li class="arch-row">
        <a class="arch-link" href={`/posts/${p.slug}/`}>
          <span class="arch-num">
            {p.data.number !== undefined ? `№ ${String(p.data.number).padStart(3, '0')}` : '·'}
          </span>
          <span class="arch-body">
            <span class="arch-title">{p.data.title}</span>
            {p.data.blurb && <span class="arch-blurb">{p.data.blurb}</span>}
          </span>
          <time class="arch-date" datetime={p.data.date.toISOString()}>{fmt(p.data.date)}</time>
        </a>
      </li>
    ))}
  </ol>

  {page.lastPage > 1 && (
    <nav class="pager">
      {page.url.prev ? <a href={page.url.prev}>&larr; Newer</a> : <span class="off">&larr; Newer</span>}
      <span class="pager-mid">{page.currentPage} / {page.lastPage}</span>
      {page.url.next ? <a href={page.url.next}>Older &rarr;</a> : <span class="off">Older &rarr;</span>}
    </nav>
  )}
</Base>

<style>
  .arch-count { margin-bottom: 1.25rem; }
  .arch { list-style: none; margin: 0; padding: 0; border-top: 1px solid var(--rule); }
  .arch-row { border-bottom: 1px solid var(--rule); }
  .arch-link {
    display: grid; grid-template-columns: 4.2rem 1fr auto; gap: 1rem; align-items: baseline;
    padding: 0.7rem 0.3rem; text-decoration: none; color: var(--ink);
  }
  .arch-link:hover { background: var(--surface); }
  .arch-num { font-family: var(--mono); font-size: 0.72rem; color: var(--land); }
  .arch-title { font-weight: 600; text-decoration: underline; text-underline-offset: 2px; text-decoration-color: var(--rule); }
  .arch-link:hover .arch-title { text-decoration-color: var(--accent); }
  .arch-blurb { display: block; color: var(--muted); font-size: 0.86rem; line-height: 1.45; margin-top: 0.15rem; }
  .arch-date { font-family: var(--sans); font-size: 0.72rem; color: var(--muted); white-space: nowrap; }

  .pager { display: flex; justify-content: space-between; align-items: center; margin-top: 2rem; font-family: var(--sans); font-size: 0.85rem; }
  .pager .off { color: var(--rule); }
  .pager-mid { font-family: var(--mono); font-size: 0.75rem; color: var(--muted); }

  @media (max-width: 560px) {
    .arch-link { grid-template-columns: 3.4rem 1fr; }
    .arch-date { grid-column: 2; margin-top: 0.2rem; }
  }
</style>
