---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const epoch = new Date('1971-01-01').valueOf();

const postItems = await getCollection('posts', ({ data }) => !data.draft && data.date.valueOf() >= epoch);
const songItems = await getCollection('songs', ({ data }) => !data.draft);
const appItems = await getCollection('apps', ({ data }) => !data.draft);
const podItems = await getCollection('episodes', ({ data }) => !data.draft);
const cityItems = await getCollection('cities', ({ data }) => !data.draft);

// Build a number -> {href, label} map per pillar so a filled cell links to the work.
// `numOf` exists because episodes count with `episode:` rather than `number:`.
function mapByNumber(
  items: any[],
  hrefFor: (i: any) => string,
  numOf: (i: any) => number | undefined = (i) => i.data.number
) {
  const m = new Map<number, { href: string; label: string }>();
  let fallback = 0;
  for (const it of items.sort((a, b) => (numOf(a) ?? 1e9) - (numOf(b) ?? 1e9))) {
    const n = numOf(it) ?? fallback;
    m.set(n, { href: hrefFor(it), label: it.data.title });
    fallback = Math.max(fallback, n) + 1;
  }
  return m;
}

const essays = mapByNumber(postItems, (i) => `/posts/${i.slug}/`);
const songs = mapByNumber(songItems, () => '/songs/');
const apps = mapByNumber(appItems, (i) => i.data.url ?? '/apps/');
const pods = mapByNumber(podItems, (i) => `/podcast/${i.slug}/`, (i) => i.data.episode);
const cities = mapByNumber(cityItems, (i) => i.data.url ?? '/cities/');

const pillars = [
  { key: 'essays', label: 'Essays', href: '/posts/', map: essays, line: 'The written word.' },
  { key: 'songs', label: 'Songs', href: '/songs/', map: songs, line: 'The felt word.' },
  { key: 'apps', label: 'Apps', href: '/apps/', map: apps, line: 'The built word.' },
  { key: 'podcasts', label: 'Podcasts', href: '/podcast/', map: pods, line: 'The spoken word.' },
  { key: 'cities', label: 'City-states', href: '/cities/', map: cities, line: 'The governed word.' },
];

const SLOTS = 1000;
const total = essays.size + songs.size + apps.size + pods.size + cities.size;
const cells = Array.from({ length: SLOTS }, (_, n) => n);
---

<Base title="The Work · Pangaea" description="A body of work: 1,000 essays, 1,000 songs, 1,000 apps. 3,000 pieces, made in public.">
  <h1>The Work</h1>
  <p class="hero">
    One body of work, five pillars, five thousand pieces: a thousand essays, a
    thousand songs, a thousand apps, a thousand conversations, a thousand
    city-states. Made in public, owned forever. Every slot below is a piece
    waiting to exist; the lit ones are done. Toward
    <strong>{total.toLocaleString()} / 5,000</strong>.
  </p>

  {pillars.map((p) => (
    <section class="pillar-block" data-pillar={p.key}>
      <div class="pillar-head">
        <a class="pillar-name" href={p.href}>{p.label}</a>
        <span class="pillar-tally">{p.map.size} <span class="of">/ 1,000</span></span>
        <span class="pillar-line">{p.line}</span>
      </div>
      <div class={`slots slots-${p.key}`}>
        {cells.map((n) => {
          const hit = p.map.get(n);
          return hit ? (
            <a
              class="slot filled"
              href={hit.href}
              title={`№ ${String(n).padStart(3, '0')} — ${hit.label}`}
            ></a>
          ) : (
            <span class="slot empty" title={`№ ${String(n).padStart(3, '0')} — open`}></span>
          );
        })}
      </div>
    </section>
  ))}

  <p class="meta" style="margin-top:2.5rem;">
    New here? <a href="/start/">Start here</a>. Also: <a href="/podcast/">the podcast</a>,
    <a href="/vlog/">the vlogs</a>, <a href="/graph/">the graph</a>.
  </p>
</Base>

<style>
  .pillar-block { margin: 2.5rem 0 0; }
  .pillar-head {
    display: flex; align-items: baseline; gap: 0.75rem; flex-wrap: wrap;
    border-bottom: 1px solid var(--rule); padding-bottom: 0.5rem; margin-bottom: 0.9rem;
  }
  .pillar-name { font-size: 1.3rem; font-weight: 600; text-decoration: none; color: var(--ink); }
  .pillar-name:hover { color: var(--accent); }
  .pillar-tally { font-family: var(--mono); font-size: 1.1rem; color: var(--accent); }
  .pillar-tally .of { color: var(--muted); font-size: 0.8rem; }
  .pillar-line { color: var(--muted); font-size: 0.9rem; margin-left: auto; }

  /* The 1,000-slot grid: a field of the whole body of work. Blue by depth. */
  .slots {
    display: grid;
    grid-template-columns: repeat(50, 1fr);
    gap: 2px;
  }
  .slot {
    aspect-ratio: 1;
    border-radius: 1px;
    background: rgba(20, 32, 31, 0.05); /* faint empty slot */
  }
  .slot.filled { cursor: pointer; transition: transform 0.08s, filter 0.08s; }
  .slot.filled:hover { transform: scale(1.6); filter: brightness(1.15); position: relative; z-index: 2; }
  /* Ocean depths, one blue per pillar */
  .slots-essays .slot.filled { background: #0c3a4b; }
  .slots-songs .slot.filled { background: #176079; }
  .slots-apps .slot.filled { background: #3f97b3; }
  .slots-podcasts .slot.filled { background: #79bfd4; }
  .slots-cities .slot.filled { background: #2f6b4f; }

  @media (max-width: 640px) {
    .slots { grid-template-columns: repeat(30, 1fr); }
    .pillar-line { margin-left: 0; width: 100%; }
  }
</style>
