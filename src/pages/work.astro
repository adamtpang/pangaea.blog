---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const epoch = new Date('1971-01-01').valueOf();
const essays = (await getCollection('posts', ({ data }) => !data.draft && data.date.valueOf() >= epoch)).length;
const songs = (await getCollection('songs', ({ data }) => !data.draft)).length;
const apps = (await getCollection('apps', ({ data }) => !data.draft)).length;

const pillars = [
  { label: 'Essays', count: essays, href: '/posts/', line: 'The written word. One claim, plainly said.' },
  { label: 'Songs', count: songs, href: '/songs/', line: 'The felt word. What would not fit in language.' },
  { label: 'Apps', count: apps, href: '/apps/', line: 'The built word. Ideas you can use.' },
];
const total = essays + songs + apps;
---

<Base title="The Work · Pangaea" description="A body of work: 1,000 essays, 1,000 songs, 1,000 apps.">
  <h1>The Work</h1>
  <p class="hero">
    One body of work, three pillars: a thousand essays, a thousand songs, a
    thousand apps. Made in public, owned forever, compounding toward
    <strong>{total.toLocaleString()} / 3,000</strong>.
  </p>

  <div class="pillars">
    {pillars.map((p) => (
      <a class="pillar" href={p.href}>
        <span class="pillar-count">{p.count}<span class="pillar-of"> / 1,000</span></span>
        <span class="pillar-label">{p.label}</span>
        <span class="pillar-line">{p.line}</span>
      </a>
    ))}
  </div>

  <p class="meta" style="margin-top:2rem;">
    Also here: <a href="/podcast/">the podcast</a>, <a href="/vlog/">the vlogs</a>,
    and <a href="/graph/">the graph</a> that ties the essays together.
    New here? <a href="/start/">Start here</a>.
  </p>
</Base>

<style>
  .pillars { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; margin: 2rem 0 0; }
  .pillar {
    display: flex; flex-direction: column; gap: 0.35rem;
    text-decoration: none; color: var(--ink);
    border-top: 2px solid var(--land); padding: 1rem 0 1.25rem;
  }
  .pillar:hover .pillar-label { color: var(--accent); }
  .pillar-count { font-family: var(--serif); font-size: 2.4rem; line-height: 1; color: var(--land); font-weight: 600; }
  .pillar-of { font-size: 0.95rem; color: var(--muted); font-weight: 400; }
  .pillar-label { font-weight: 600; font-size: 1.1rem; transition: color 0.1s; }
  .pillar-line { color: var(--muted); font-size: 0.9rem; line-height: 1.45; }
  @media (max-width: 540px) { .pillars { grid-template-columns: 1fr; gap: 0.5rem; } }
</style>
